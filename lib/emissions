// lib/emissions.js
// The carbon accounting engine for Carbon of War
// All emission factors sourced from peer-reviewed literature:
// - Neta Crawford, "Pentagon Fuel Use, Climate Change, and the Costs of War" (2019)
// - Conflict and Environment Observatory (CEOBS) methodology reports
// - IPCC AR6 emission factors for land use change and fires

export const EMISSION_FACTORS = {
  // Direct military operations — tons CO2-eq per event
  // Based on fuel consumption × IPCC emission factor for jet fuel/diesel
  'Air strike': { low: 45, mid: 120, high: 280, category: 'direct' },
  'Shelling': { low: 8, mid: 22, high: 55, category: 'direct' },
  'Armed clash': { low: 3, mid: 9, high: 25, category: 'direct' },
  'Drone strike': { low: 2, mid: 6, high: 18, category: 'direct' },
  'Missile strike': { low: 60, mid: 180, high: 420, category: 'direct' },
  'Naval attack': { low: 80, mid: 240, high: 600, category: 'direct' },
  'Tank battle': { low: 25, mid: 75, high: 200, category: 'direct' },
  // Infrastructure destruction — embodied carbon release
  // Based on ICE database embodied carbon values × typical structure sizes
  'Infrastructure destroyed': { low: 200, mid: 800, high: 2500, category: 'infrastructure' },
  'Building destroyed': { low: 50, mid: 180, high: 500, category: 'infrastructure' },
  // Default fallback for uncategorized ACLED events
  'default': { low: 5, mid: 15, high: 40, category: 'direct' },
}

// How many conflict events happen per second across all active wars
// Derived from ACLED 2023-2024 global event rates (~180,000 events/year)
export const EVENTS_PER_SECOND = 180000 / (365 * 24 * 3600)

// Average tons CO2-eq per event (mid estimate)
export const AVG_TONS_PER_EVENT = 18.5

// Therefore: tons emitted per second globally from conflict
export const TONS_PER_SECOND = EVENTS_PER_SECOND * AVG_TONS_PER_EVENT

// Human-scale equivalences for any given tonnage of CO2-eq
export function getEquivalences(tons) {
  return [
    {
      label: 'Transatlantic flights',
      value: Math.round(tons / 0.9),
      icon: 'plane',
    },
    {
      label: 'Cars driven for a year',
      value: Math.round(tons / 4.6),
      icon: 'car',
    },
    {
      label: 'Homes powered for a year',
      value: Math.round(tons / 7.5),
      icon: 'home',
    },
    {
      label: 'Coal plants running for a day',
      value: Math.round(tons / 10960),
      icon: 'factory',
    },
  ]
}

// Given an ACLED event object, return estimated emissions
export function estimateEventEmissions(event) {
  const type = event.sub_event_type || event.event_type || 'default'
  const factor = EMISSION_FACTORS[type] || EMISSION_FACTORS['default']
  return {
    low: factor.low,
    mid: factor.mid,
    high: factor.high,
    category: factor.category,
    eventType: type,
  }
}

// Aggregate total emissions from an array of events
export function aggregateEmissions(events) {
  return events.reduce((total, event) => {
    const est = estimateEventEmissions(event)
    return {
      low: total.low + est.low,
      mid: total.mid + est.mid,
      high: total.high + est.high,
    }
  }, { low: 0, mid: 0, high: 0 })
}

// Format a large number into readable string (e.g. 1,240,000 → "1.24M")
export function formatTons(tons) {
  if (tons >= 1_000_000_000) return `${(tons / 1_000_000_000).toFixed(2)}B`
  if (tons >= 1_000_000) return `${(tons / 1_000_000).toFixed(2)}M`
  if (tons >= 1_000) return `${(tons / 1_000).toFixed(1)}K`
  return Math.round(tons).toLocaleString()
}